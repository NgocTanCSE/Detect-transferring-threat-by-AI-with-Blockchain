# Blockchain Sentinel Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env with real API keys to git.

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=blockchain_db
DATABASE_URL=sqlite:///blockchain_local.db
# DATABASE_URL=postgresql://user:password@db:5432/blockchain_db

# ============================================
# ALCHEMY API (Required for real blockchain data)
# ============================================
# Get your API key at: https://dashboard.alchemy.com/
ALCHEMY_API_KEY=your_alchemy_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# Using gemini-2.5-flash (newest, most stable)
GEMINI_MODEL=gemini-2.5-flash

# ============================================
# BACKEND CONFIGURATION
# ============================================
BACKEND_API_URL=http://backend:8000

# ============================================
# DEMO WALLET CONFIGURATION
# ============================================
DEMO_FUNDED_ADDRESS=0x742d35Cc6634C0532925a3b844Bc454e4438f44e
DEMO_INITIAL_BALANCE_ETH=1000

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_SENDER_ADDRESS=0x742d35Cc6634C0532925a3b844Bc454e4438f44e

# ============================================
# SCANNER CONFIGURATION
# ============================================
SCAN_INTERVAL=30
BLOCK_THRESHOLD=80
WARNING_THRESHOLD=50
RESET_DB=0

# ============================================
# SECURITY SETTINGS
# ============================================
MAX_WARNINGS=3
JWT_SECRET=change_this_to_a_strong_random_secret_in_production

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
DEBUG=False
LOG_LEVEL=INFO
