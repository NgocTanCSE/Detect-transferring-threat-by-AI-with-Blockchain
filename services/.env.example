# =====================================
# Blockchain AI - Microservices Stack
# Environment Configuration Example
# =====================================

# Service Configuration
NODE_ENV=development
DEBUG=false

# ==================
# Service Ports
# ==================
PORT=8001  # API Gateway

# ==================
# Database Configuration
# ==================
# Main Database (Auth, Wallet, Compliance)
DATABASE_URL=postgresql://blockchain:blockchain123@postgres_main:5432/blockchain_main

# Alert Database
ALERT_DATABASE_URL=postgresql://blockchain:blockchain123@postgres_alerts:5432/blockchain_alerts

# Transfer Database
TRANSFER_DATABASE_URL=postgresql://blockchain:blockchain123@postgres_transfers:5432/blockchain_transfers

# ==================
# Message Queue
# ==================
RABBITMQ_URL=amqp://admin:admin123@rabbitmq:5672
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672

# ==================
# Service URLs (Inter-service communication)
# ==================
AUTH_SERVICE_URL=http://auth-service:3001
WALLET_SERVICE_URL=http://wallet-service:3002
ALERT_SERVICE_URL=http://alert-service:3003
TRANSFER_SERVICE_URL=http://transfer-service:3004
ANALYTICS_SERVICE_URL=http://analytics-service:3005
COMPLIANCE_SERVICE_URL=http://compliance-service:3006
EVENT_SERVICE_URL=http://event-service:3007

# ==================
# Security
# ==================
JWT_SECRET=your_jwt_secret_key_here_change_in_production_at_least_32_chars
JWT_EXPIRY=7d
JWT_ALGORITHM=HS256

# ==================
# External APIs
# ==================
ALCHEMY_API_KEY=your_alchemy_key_here
ETHERSCAN_API_KEY=your_etherscan_key_here
ETHERSCAN_API_URL=https://api.etherscan.io/api

# ==================
# Blockchain Configuration
# ==================
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/
BSC_RPC_URL=https://bsc-dataseed1.binance.org:8545

# ==================
# Feature Flags
# ==================
ENABLE_AI_ANALYSIS=true
ENABLE_REAL_TIME_ALERTS=true
ENABLE_COMPLIANCE_CHECKS=true

# ==================
# Logging & Monitoring
# ==================
LOG_LEVEL=info
SENTRY_DSN=

# ==================
# Frontend
# ==================
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ==================
# Rate Limiting
# ==================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
